{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AgentFramework": {
    "EnableDetailedLogging": true,
    "ExecutionTimeout": 30000,
    "MaxRetries": 3,
    "RetryPolicy": {
      "MaxRetries": 3,
      "DelayMs": 1000,
      "BackoffMultiplier": 2.0
    },
    "StateManagement": {
      "Provider": "InMemory",
      "TTL": 3600
    }
  },
  "Gatekeeper": {
    "ReviewApprovalThreshold": 80,
    "AnalysisQualityThreshold": 70,
    "SecurityScoreThreshold": 75,
    "MaxConcurrentAnalyses": 100
  }
}
